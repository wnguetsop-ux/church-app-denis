rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Gallery images/videos - public read, auth write
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024; // max 20MB
    }

    // Sermon thumbnails
    match /sermons/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // Teaching audio files
    match /teachings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024; // max 50MB for audio
    }

    // General uploads
    match /uploads/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
