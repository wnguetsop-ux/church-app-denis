rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for all content collections
    match /sermons/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /teachings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /announcements/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /events/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /donationMethods/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /churchInfo/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Prayers - public can create, admin can read/update/delete
    match /prayers/{doc} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Notifications - admin only
    match /notifications/{doc} {
      allow read, write: if request.auth != null;
    }

    // Contact form submissions - public can create, admin reads
    match /contacts/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
